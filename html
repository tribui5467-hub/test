<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Algebra Practice - Study Module</title>
<link id="favicon" rel="icon" type="image/webp" href="noFilter.webp">
    <link href="https://fonts.googleapis.com/css2?family=Chewy&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root { --primary: #a855f7; --accent: #22c55e; --bg: #020617; --text: #ffffff; --card: rgba(30, 41, 59, 0.5); }
        body { 
            background-color: var(--bg); color: var(--text); font-family: 'Chewy', cursive;
            transition: all 0.3s ease; overflow-x: hidden; min-height: 100vh;
            background-size: cover; background-position: center; background-attachment: fixed;
        }
        #particle-canvas { position: fixed; top: 0; left: 0; z-index: -1; pointer-events: none; }
        
        .main-logo-container { display: flex; justify-content: center; padding-top: 40px; margin-bottom: -10px; }
        .main-logo { width: 350px; height: auto; filter: drop-shadow(0 0 15px var(--primary)); cursor: pointer; transition: transform 0.3s ease, filter 0.3s ease; }
        .main-logo:hover { transform: scale(1.05); }

        .island-header {
            background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 99px;
            padding: 10px 28px; display: flex; align-items: center; gap: 20px;
            margin: 20px auto 40px; width: fit-content; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .nav-icon { font-size: 1.5rem; cursor: pointer; transition: color 0.2s; opacity: 0.7; }
        .nav-icon:hover { color: var(--primary) !important; opacity: 1; }
        
        .penguin-nav-btn { height: 40px; width: 40px; object-fit: contain; cursor: pointer; transition: filter 0.3s; }
        .penguin-nav-btn:hover { filter: drop-shadow(0 0 8px var(--primary)); }

        .game-card, .sidebar-card, .backup-card {
            position: relative; aspect-ratio: 1/1; overflow: hidden; border-radius: 1.2rem;
            border: 2px solid transparent; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--card); cursor: pointer;
        }
        .game-card:hover, .sidebar-card:hover, .backup-card:hover { border-color: var(--primary); transform: scale(1.03); box-shadow: 0 0 15px var(--primary); }
        .game-card img, .sidebar-card img { width: 100%; height: 100%; object-fit: cover; }
        
        .backup-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 15px; text-align: center; padding: 20px; }
        .backup-card i { font-size: 3.5rem; color: var(--primary); transition: color 0.3s ease; }
        .backup-label { color: #fff; font-size: 1.1rem; width: 100%; text-align: center; display: block; }

        .card-title {
            position: absolute; bottom: -100%; left: 0; width: 100%;
            background: linear-gradient(transparent, rgba(0,0,0,0.9));
            padding: 20px 5px 10px; text-align: center; transition: bottom 0.3s ease; font-size: 0.8rem;
        }
        .game-card:hover .card-title, .sidebar-card:hover .card-title, .backup-card:hover .card-title { bottom: 0; }

        #settingsPanel { z-index: 100; transition: transform 0.4s ease; }
        .game-container { display: grid; grid-template-columns: 1fr 300px; gap: 20px; height: calc(100vh - 100px); padding: 20px; }
        
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        ::-webkit-scrollbar-thumb { background: var(--primary); border-radius: 10px; border: 2px solid var(--bg); }

        .download-here-link { color: #3b82f6; font-weight: bold; cursor: pointer; text-decoration: underline; }
        .download-here-link:hover { color: #60a5fa; }
    </style>
</head>
<body class="p-4">

    <canvas id="particle-canvas"></canvas>

    <div id="downloadPopup" class="fixed inset-0 bg-black/80 backdrop-blur-md z-[300] hidden flex items-center justify-center">
        <div class="bg-slate-900 border border-white/10 p-8 rounded-3xl max-w-md text-center shadow-2xl">
            <h2 class="text-2xl mb-4 text-white">Algebra Practise Downloadable File</h2>
            <p class="text-lg mb-6">You can now download the site as a file on your computer! <br> 
               Download it <span class="download-here-link" onclick="downloadFile()">here</span>.
            </p>
            <div class="flex items-center justify-center gap-3 mb-6">
                <input type="checkbox" id="dontShowAgain" class="w-4 h-4 cursor-pointer">
                <label for="dontShowAgain" class="text-sm opacity-80 cursor-pointer">Do not show again</label>
            </div>
            <button onclick="closePopup()" class="bg-white/10 px-8 py-2 rounded-full hover:bg-white/20 transition-all">Close</button>
        </div>
    </div>

    <div class="main-logo-container">
        <img id="mainLogoImg" src="" alt="Logo" class="main-logo" onclick="location.reload()">
    </div>

    <header class="island-header">
        <img id="penguinHeadImg" src="" onclick="location.reload()" class="penguin-nav-btn" title="Home">
        <div class="h-6 w-[1px] bg-white/20"></div>
        <i class="fas fa-gamepad nav-icon" onclick="renderGames('games')" title="Games"></i>
        <i class="fas fa-th-large nav-icon" onclick="renderGames('apps')" title="Apps"></i>
        <i class="fas fa-dice nav-icon" onclick="openRandomGame()" title="Random Game"></i>
        <i class="fas fa-link nav-icon" onclick="renderGames('backups')" title="Backups"></i>
        <i class="fas fa-circle-info nav-icon" onclick="toggleInfo()" title="Info"></i>
        <div class="relative">
            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-sm opacity-50"></i>
            <input type="text" id="searchInput" placeholder="Search..." 
                   class="bg-white/5 border border-white/10 py-1 pl-9 pr-4 rounded-full focus:outline-none focus:ring-1 focus:ring-primary text-sm w-32 md:w-48">
        </div>
        <i class="fas fa-sliders nav-icon" onclick="toggleSettings()"></i>
    </header>

    <main class="max-w-7xl mx-auto">
        <div id="gameGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-5"></div>
    </main>

    <div id="infoTab" class="fixed inset-0 bg-black/80 backdrop-blur-md z-[200] hidden flex items-center justify-center" onclick="toggleInfo()">
        <div class="bg-slate-900 border border-white/10 p-8 rounded-3xl max-w-md text-center shadow-2xl" onclick="event.stopPropagation()">
            <h2 class="text-3xl mb-4" style="color: var(--primary);">About Algebra Practice</h2>
            <p class="text-lg leading-relaxed mb-4">Algebra Practise was created by hazza in 2025 and updated in 2026. i dont own any of the games here apart from the ones i made.</p>
            <p class="text-lg mb-6">Request games <a href="https://docs.google.com/forms/d/e/1FAIpQLScww3MHYoLogsOX5WcBctTbzVTUkXwoEeiOxenN0i8gxiOtpg/viewform?usp=header" target="_blank" class="text-blue-500 underline">here</a></p>
            
            <div class="flex flex-col gap-3">
                <button onclick="downloadFile()" class="flex items-center justify-center gap-2 py-3 rounded-xl text-white font-bold transition-all hover:scale-105 active:scale-95" style="background-color: var(--primary);">
                    <i class="fas fa-download"></i> Download Offline File
                </button>
                <button onclick="toggleInfo()" class="bg-white/10 px-6 py-2 rounded-full hover:bg-white/20 transition-all">Close</button>
            </div>
        </div>
    </div>

    <div id="settingsPanel" class="fixed top-0 right-0 h-full w-80 bg-slate-900 border-l border-white/10 p-8 transform translate-x-full shadow-2xl overflow-y-auto">
        <div class="flex justify-between items-center mb-8">
            <h2 class="text-3xl">Settings</h2>
            <button onclick="toggleSettings()"><i class="fas fa-times text-xl"></i></button>
        </div>
        <div class="space-y-6">
            <div>
                <label class="block text-xs opacity-50 mb-2 uppercase">Theme Color</label>
                <input type="color" id="primaryPicker" value="#a855f7" oninput="updatePrimary(this.value)" class="w-full h-10 rounded-lg cursor-pointer bg-transparent border-none">
            </div>
            <div class="flex items-center justify-between bg-white/5 p-3 rounded-xl">
                <span>Particles</span>
                <button id="partToggle" onclick="toggleParticles()" style="color: var(--primary);">ON</button>
            </div>
            <button onclick="setBg()" class="w-full bg-white/10 py-3 rounded-xl text-sm">Set Background Image</button>
            <button onclick="resetBg()" class="w-full bg-red-500/10 text-red-400 py-2 rounded-xl text-xs">Reset Background</button>
            <button onclick="openAboutBlank()" class="w-full bg-white/10 py-3 rounded-xl text-sm">Open in About:Blank</button>
            <div class="space-y-3 pt-4 border-t border-white/10 flex flex-col">
                <input type="text" id="cloakTitle" placeholder="Tab Title" class="w-full bg-white/5 border border-white/10 p-2 rounded-lg text-sm">
                <input type="text" id="cloakFavicon" placeholder="Favicon URL" class="w-full bg-white/5 border border-white/10 p-2 rounded-lg text-sm">
                <button onclick="applyCloak()" id="applyBtn" class="w-full text-black py-3 px-4 rounded-xl text-sm font-bold shadow-lg hover:brightness-110 transition-all mt-2" style="background-color: var(--primary);">Apply Cloak</button>
            </div>
        </div>
    </div>

    <div id="gameModal" class="fixed inset-0 z-[110] hidden bg-black/95 flex flex-col">
        <div class="game-container">
            <div class="bg-black rounded-2xl overflow-hidden border border-white/5">
                <div id="iframeContainer" class="w-full h-full"></div>
            </div>
            <div class="sidebar hidden lg:flex flex-col gap-4 overflow-y-auto pr-2">
                <h3 class="text-xl" style="color: var(--primary);">More Like This</h3>
                <div id="suggestedGames" class="grid grid-cols-2 gap-3"></div>
            </div>
        </div>
        <div class="h-20 px-8 flex items-center justify-between bg-white/5 backdrop-blur-md">
            <div class="flex items-center gap-4">
                <img id="modalIcon" src="" class="h-10 w-10 rounded-lg object-cover">
                <h3 id="modalTitle" class="text-xl">Game Title</h3>
            </div>
            <div class="flex items-center gap-8">
                <button onclick="openAboutBlank()" class="nav-icon" title="Open in About:Blank"><i class="fas fa-mask text-xl"></i></button>
                <button onclick="toggleFullscreen()" class="nav-icon"><i class="fas fa-expand text-xl"></i></button>
                <button onclick="closeGame()" class="text-red-500 text-2xl"><i class="fas fa-times"></i></button>
            </div>
        </div>
    </div>

<script>
    const repoOwner = "hazzatazza";
    const repoName = "algebruh-practise";
    const cdnBase = `https://cdn.jsdelivr.net/gh/${repoOwner}/${repoName}@main/`;
    
    let games = []; 
    let backups = []; 
    let currentLatestSha = "";

    function closePopup() {
        if (document.getElementById('dontShowAgain').checked) {
            localStorage.setItem('hideDownloadPopup', 'true');
        }
        document.getElementById('downloadPopup').classList.add('hidden');
    }

    async function downloadFile() {
        try {
            // SHA Fetch for Cache Busting
            const shaResponse = await fetch(`https://api.github.com/repos/${repoOwner}/${repoName}/commits?t=${Date.now()}`);
            const commits = await shaResponse.json();
            const sha = commits[0].sha;

            const fileUrl = `https://cdn.jsdelivr.net/gh/${repoOwner}/${repoName}@${sha}/algebraofficialfile.html`;
            
            const response = await fetch(fileUrl);
            if (!response.ok) throw new Error('Fetch failed');
            
            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'algebraofficialfile.html';
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        } catch (e) {
            console.error("Download failed", e);
            alert("Download failed. Make sure the file exists in your repository.");
        }
    }

    async function loadData() {
        try {
            document.getElementById('mainLogoImg').src = cdnBase + 'logo.png';
            document.getElementById('penguinHeadImg').src = cdnBase + 'penguinhead.png';
            
            const shaResponse = await fetch(`https://api.github.com/repos/${repoOwner}/${repoName}/commits?t=${Date.now()}`);
            const commits = await shaResponse.json();
            currentLatestSha = commits[0].sha;

            const gamesResponse = await fetch(`https://cdn.jsdelivr.net/gh/${repoOwner}/${repoName}@${currentLatestSha}/games.json`);
            games = await gamesResponse.json();
            const linksResponse = await fetch(`https://cdn.jsdelivr.net/gh/${repoOwner}/${repoName}@${currentLatestSha}/links.json`);
            backups = await linksResponse.json();
            renderGames('games');
        } catch (error) { console.error("Error loading data:", error); }
    }

    function renderGames(filter = 'games', search = '') {
        const grid = document.getElementById('gameGrid');
        grid.innerHTML = '';
        let items = filter === 'backups' ? backups : games;
        items.forEach(item => {
            if (filter === 'apps' && item.type !== 'app') return;
            if (filter === 'games' && item.type === 'app') return;
            if (search && !item.title.toLowerCase().includes(search.toLowerCase())) return;
            const card = document.createElement('div');
            if(filter === 'backups') {
                card.className = 'backup-card';
                card.onclick = () => window.open(item.url, '_blank');
                card.innerHTML = `<i class="fas ${item.icon}"></i><div class="backup-label">${item.title}</div>`;
            } else {
                card.className = 'game-card';
                card.onclick = () => openGame(item.id);
                card.innerHTML = `<img src="${cdnBase}${item.thumb}" loading="lazy"><div class="card-title">${item.title}</div>`;
            }
            grid.appendChild(card);
        });
    }

    function openGame(id) {
        const game = games.find(g => g.id === id);
        if(!game) return;
        document.getElementById('modalTitle').textContent = game.title;
        document.getElementById('modalIcon').src = cdnBase + game.thumb;
        document.getElementById('iframeContainer').innerHTML = `<iframe id="gameIframe" src="${game.url}" class="w-full h-full border-none" allowfullscreen></iframe>`;
        document.getElementById('gameModal').classList.remove('hidden');
        const suggested = games.filter(g => g.id !== id).sort(() => 0.5 - Math.random()).slice(0, 6);
        const suggGrid = document.getElementById('suggestedGames');
        suggGrid.innerHTML = '';
        suggested.forEach(g => {
            const scard = document.createElement('div');
            scard.className = 'sidebar-card';
            scard.onclick = () => openGame(g.id);
            scard.innerHTML = `<img src="${cdnBase}${g.thumb}"><div class="card-title">${g.title}</div>`;
            suggGrid.appendChild(scard);
        });
    }

    function closeGame() {
        document.getElementById('gameModal').classList.add('hidden');
        document.getElementById('iframeContainer').innerHTML = '';
    }

    function openRandomGame() {
        if(games.length > 0) openGame(games[Math.floor(Math.random() * games.length)].id);
    }

    function toggleFullscreen() {
        const el = document.getElementById('gameIframe');
        if (el && el.requestFullscreen) { el.requestFullscreen(); }
    }

    function openAboutBlank() {
        const iframe = document.getElementById('gameIframe');
        const targetUrl = iframe ? iframe.src : window.location.href;
        const win = window.open();
        if (!win) return alert("Please allow popups!");
        const doc = win.document;
        const body = doc.body;
        const outerIframe = doc.createElement('iframe');
        doc.title = document.title;
        const link = doc.createElement('link');
        link.rel = 'icon';
        link.href = document.getElementById('favicon').href;
        doc.head.appendChild(link);
        outerIframe.style.width = "100%";
        outerIframe.style.height = "100%";
        outerIframe.style.border = "none";
        outerIframe.style.position = "fixed";
        outerIframe.style.top = "0";
        outerIframe.style.left = "0";
        outerIframe.src = targetUrl;
        body.appendChild(outerIframe);
        body.style.margin = "0";
        body.style.padding = "0";
    }

    function applyCloak() {
        const title = document.getElementById('cloakTitle').value;
        const icon = document.getElementById('cloakFavicon').value;
        if(title) document.title = title;
        if(icon) document.getElementById('favicon').href = icon;
        localStorage.setItem('user_cloak_title', title);
        localStorage.setItem('user_cloak_icon', icon);
    }

    function updatePrimary(color) {
        document.documentElement.style.setProperty('--primary', color);
        const applyBtn = document.getElementById('applyBtn');
        if(applyBtn) applyBtn.style.backgroundColor = color;
        localStorage.setItem('user_p_color', color);
    }

    let particlesEnabled = localStorage.getItem('particles') !== 'false';
    function toggleParticles() {
        particlesEnabled = !particlesEnabled;
        localStorage.setItem('particles', particlesEnabled);
        document.getElementById('partToggle').textContent = particlesEnabled ? 'ON' : 'OFF';
        document.getElementById('partToggle').style.color = particlesEnabled ? getComputedStyle(document.documentElement).getPropertyValue('--primary') : '#ef4444';
    }

    function toggleSettings() {
        const panel = document.getElementById('settingsPanel');
        panel.style.transform = panel.style.transform === 'translateX(0%)' ? 'translateX(100%)' : 'translateX(0%)';
    }

    function toggleInfo() {
        document.getElementById('infoTab').classList.toggle('hidden');
    }

    function setBg() {
        const url = prompt("Enter Image URL:");
        if(url) {
            document.body.style.backgroundImage = `url('${url}')`;
            localStorage.setItem('user_bg', url);
        }
    }
    function resetBg() {
        document.body.style.backgroundImage = 'none';
        localStorage.removeItem('user_bg');
    }

    const canvas = document.getElementById('particle-canvas');
    const ctx = canvas.getContext('2d');
    let pts = [];
    function initPts() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; pts = Array(40).fill().map(() => ({ x:Math.random()*canvas.width, y:Math.random()*canvas.height, s:Math.random()*2, v:Math.random()*0.5+0.2 })); }
    function draw() {
        if(!particlesEnabled) { ctx.clearRect(0,0,canvas.width,canvas.height); return requestAnimationFrame(draw); }
        ctx.clearRect(0,0,canvas.width,canvas.height);
        ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--primary');
        pts.forEach(p => { p.y -= p.v; if(p.y<0) p.y=canvas.height; ctx.beginPath(); ctx.arc(p.x,p.y,p.s,0,7); ctx.fill(); });
        requestAnimationFrame(draw);
    }

    window.onload = () => {
        if (localStorage.getItem('hideDownloadPopup') !== 'true') {
            document.getElementById('downloadPopup').classList.remove('hidden');
        }

        const savedColor = localStorage.getItem('user_p_color') || '#a855f7';
        updatePrimary(savedColor); 
        document.getElementById('primaryPicker').value = savedColor;
        const sBg = localStorage.getItem('user_bg');
        if(sBg) document.body.style.backgroundImage = `url('${sBg}')`;
        const sTitle = localStorage.getItem('user_cloak_title');
        const sIcon = localStorage.getItem('user_cloak_icon');
        if(sTitle) document.title = sTitle;
        if(sIcon) document.getElementById('favicon').href = sIcon;
        loadData();
        initPts(); draw();
    };

    document.getElementById('searchInput').oninput = (e) => renderGames('games', e.target.value);
    window.onresize = initPts;
</script>
</body>
</html>
